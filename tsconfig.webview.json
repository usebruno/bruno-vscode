{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist/webview",
    "rootDir": "./src/webview",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "types": ["node"]
  },
  "include": [
    "src/webview/**/*",
    "src/types/global.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/extension"
  ]
}
