.vscode/**
src/**
scripts/**
.yarnrc.yml
esbuild.extension.mjs
rsbuild.webview.config.mjs
postcss.config.js
tailwind.config.js
tsconfig.json
tsconfig.extension.json
tsconfig.webview.json
**/*.ts
**/*.tsx
.gitignore
.eslintrc*
*.vsix

# Exclude all node_modules by default
node_modules/**

# Include packages needed at runtime by user scripts in node-vm sandbox
# (these are require()'d dynamically, not bundled)
!node_modules/xml2js/**
!node_modules/xmlbuilder/**
!node_modules/sax/**
!node_modules/cheerio/**
!node_modules/cheerio-select/**
!node_modules/htmlparser2/**
!node_modules/dom-serializer/**
!node_modules/domhandler/**
!node_modules/domutils/**
!node_modules/entities/**
!node_modules/css-select/**
!node_modules/css-what/**
!node_modules/boolbase/**
!node_modules/nth-check/**
!node_modules/parse5/**
!node_modules/parse5-htmlparser2-tree-adapter/**
!node_modules/crypto-js/**
!node_modules/node-fetch/**
!node_modules/chai/**
!node_modules/assertion-error/**
!node_modules/check-error/**
!node_modules/deep-eql/**
!node_modules/get-func-name/**
!node_modules/loupe/**
!node_modules/pathval/**
!node_modules/type-detect/**
!node_modules/jsonwebtoken/**
!node_modules/jws/**
!node_modules/jwa/**
!node_modules/buffer-equal-constant-time/**
!node_modules/ecdsa-sig-formatter/**
!node_modules/safe-buffer/**
!node_modules/semver/**
!node_modules/ms/**
!node_modules/lodash.includes/**
!node_modules/lodash.isboolean/**
!node_modules/lodash.isinteger/**
!node_modules/lodash.isnumber/**
!node_modules/lodash.isplainobject/**
!node_modules/lodash.isstring/**
!node_modules/lodash.once/**
!node_modules/atob/**
!node_modules/btoa/**
!node_modules/ajv/**
!node_modules/ajv-formats/**
!node_modules/fast-deep-equal/**
!node_modules/json-schema-traverse/**
!node_modules/uri-js/**

# Keep dist, media, syntaxes, language-configuration.json
!dist/**
!media/**
!syntaxes/**
!language-configuration.json

# Exclude source maps from dist
dist/**/*.map
